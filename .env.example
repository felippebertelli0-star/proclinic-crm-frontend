# ============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE
# ============================================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local (desenvolvimento) ou adicione em Vercel (produção)
# 2. Substitua os valores [PLACEHOLDER] pelos valores reais
# 3. NÃO commite este arquivo com valores reais (use .gitignore)
#
# ============================================================================

# ============================================================================
# ANTHROPIC API - CRÍTICO PARA FEATURES DE IA
# ============================================================================
# Origem: https://console.anthropic.com/account/keys
# Formato: Deve começar com "sk-ant-"
# Ação: Substitua [SUA_CHAVE_ANTHROPIC_AQUI] pela chave real

ANTHROPIC_API_KEY=sk-ant-[SUA_CHAVE_ANTHROPIC_AQUI]

# ============================================================================
# BACKEND API URLs
# ============================================================================
# Estas variáveis apontam para o backend em produção (Railway)
# Em desenvolvimento, pode apontar para localhost se necessário

NEXT_PUBLIC_API_URL=https://proclinic-crm-backend-production.up.railway.app/api/v1
NEXT_PUBLIC_SOCKET_URL=https://proclinic-crm-backend-production.up.railway.app

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
# development: Modo dev com hot reload e logs detalhados
# production: Modo de produção otimizado

NODE_ENV=development

# ============================================================================
# FIM DO ARQUIVO DE CONFIGURAÇÃO
# ============================================================================
